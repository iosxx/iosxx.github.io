  <entry>
    <title>记忆回廊：遗忘的代价</title>
    <link href="https://g0f.cn/posts/a1b2c3d4-e5f6-7890-1234-567890abcdef"/>
    <id>https://g0f.cn/posts/a1b2c3d4-e5f6-7890-1234-567890abcdef</id>
